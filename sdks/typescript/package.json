{
  "name": "@jarvisclaw/agent-intent-protocol",
  "version": "2.1.0",
  "description": "Agent Intent Protocol — TypeScript SDK. One interface for all AI platform capabilities.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["ai", "agent", "intent", "protocol", "llm", "jarvisclaw", "aip"],
  "license": "MIT",
  "homepage": "https://github.com/api-jarvisclaw/agent-intent-protocol",
  "repository": {
    "type": "git",
    "url": "https://github.com/api-jarvisclaw/agent-intent-protocol.git",
    "directory": "sdks/typescript"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "eslint": "^8.57.0"
  }
}
